{
    "compilerOptions": {
        "module": "Node16",
        "esModuleInterop": true,
        "target": "es2017",
        "moduleResolution": "Node16",
        "sourceMap": true,
        "outDir": "dist",
        "resolveJsonModule": true,
        "rootDir": "generated",
        "strict": true
    },
    "include": ["generated/**/*.ts", "generated/**/*.d.ts"],
    "lib": ["es2015"]
}
